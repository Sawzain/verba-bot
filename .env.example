# Discord bot token — Developer Portal > your app > Bot tab
DISCORD_TOKEN=

# Supabase project URL and service-role key
SUPABASE_URL=
SUPABASE_KEY=

# Discord server (guild) ID
GUILD_ID=

# --- Channel IDs (optional) ---
# If not set, the bot falls back to this server's current channel IDs
# hardcoded in src/config/channelIds.js. Set these if deploying to a
# different server, or if a channel gets recreated with a new ID.
LOG_CHANNEL_ID=
WELCOME_CHANNEL_ID=
GENERAL_CHAT_CHANNEL_ID=
MEETING_CHANNEL_ID=
